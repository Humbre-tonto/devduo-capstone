# =============================================================
# DevDuo — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================

# ── crosstalk-mcp relay ──────────────────────────────────────
RELAY_URL=https://crosstalk-relay-xxx-uc.a.run.app   # from deploy_relay.sh output
RELAY_TOKEN=                                           # from deploy_relay.sh output

# ── Google / Vertex AI ───────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
GOOGLE_API_KEY=                                        # from Google AI Studio (for local dev)
# For Cloud Run, use a service account instead of API key

# ── Agent channels (don't change unless you know why) ────────
BE_TO_FE_CHANNEL=be-to-fe
FE_TO_BE_CHANNEL=fe-to-be
